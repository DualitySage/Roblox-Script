runService.RenderStepped:Connect(function()
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        -- Only override walkspeed if the player isn't currently flying
        if not isFlying and hum.WalkSpeed ~= currentSpeedValue then 
            hum.WalkSpeed = currentSpeedValue 
        end
        
        if hum.UseJumpPower then
            if hum.JumpPower ~= currentJumpValue then hum.JumpPower = currentJumpValue end
        else
            -- Maps default jump power parameters safely to platform configurations
            local convertedHeight = (currentJumpValue * currentJumpValue) / (2 * game.Workspace.Gravity)
            if hum.JumpHeight ~= convertedHeight then hum.JumpHeight = convertedHeight end
        end
    end
end)

