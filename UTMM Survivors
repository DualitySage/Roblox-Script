-- ==========================================
-- INTEGRATED FLIGHT SYSTEM CONFIGURATION
-- ==========================================
local isFlying = false
local currentFlightSpeed = 50
local flyConnection = nil
local freezeVelocity = nil

local function resetCharacterJoints()
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        local animator = hum:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                track:Stop(0)
            end
        end
    end
    if char then
        for _, motor in ipairs(char:GetDescendants()) do
            if motor:IsA("Motor6D") and motor.Name ~= "Neck" then
                motor.Transform = CFrame.new()
            end
        end
    end
end

local function stopFlying()
    if not isFlying then return end
    isFlying = false
    
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if freezeVelocity then freezeVelocity:Destroy() freezeVelocity = nil end
    
    local char = player.Character
    local animateScript = char and char:FindFirstChild("Animate")
    if animateScript then
        animateScript.Enabled = true
    end
    
    local btn = miscPanel:FindFirstChild("ToggleFlight")
    if btn then
        btn.Text = "Flight: OFF"
        btn.BackgroundColor3 = Color3.fromRGB(53, 59, 72)
    end
end

local function startFlying()
    if isFlying then return end
    local char = player.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not rootPart then return end
    
    isFlying = true
    
    local animateScript = char:FindFirstChild("Animate")
    if animateScript then
        animateScript.Enabled = false
    end
    resetCharacterJoints()
    
    rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0,0,0)
    
    freezeVelocity = Instance.new("BodyVelocity")
    freezeVelocity.Name = "StaticFlightAnchor"
    freezeVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    freezeVelocity.Velocity = Vector3.new(0, 0, 0)
    freezeVelocity.Parent = rootPart
    
    local btn = miscPanel:FindFirstChild("ToggleFlight")
    if btn then
        btn.Text = "Flight: ON"
        btn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    end
    
    local UserInputService = game:GetService("UserInputService")
    local camera = workspace.CurrentCamera
    
    flyConnection = runService.Heartbeat:Connect(function(deltaTime)
        local activeChar = player.Character
        local activeRoot = activeChar and activeChar:FindFirstChild("HumanoidRootPart")
        if not isFlying or not activeRoot then return end
        
        resetCharacterJoints()
        
        local moveDirection = Vector3.new(0, 0, 0)
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDirection = moveDirection + camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDirection = moveDirection - camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDirection = moveDirection + camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDirection = moveDirection - camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDirection = moveDirection + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            moveDirection = moveDirection - Vector3.new(0, 1, 0)
        end
        
        local lookVector = camera.CFrame.LookVector
        local targetPosition = activeRoot.Position + (moveDirection * currentFlightSpeed * deltaTime)
        
        activeRoot.CFrame = CFrame.lookAt(targetPosition, targetPosition + lookVector)
        activeRoot.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end)
end

