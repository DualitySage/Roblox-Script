local function showSection(targetPanel)
    for _, sec in ipairs(sections) do
        if sec.panel == targetPanel then
            sec.panel.Visible = true
            sec.button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        else
            sec.panel.Visible = false
            sec.button.BackgroundColor3 = Color3.fromRGB(45, 52, 54)
        end
    end
end

